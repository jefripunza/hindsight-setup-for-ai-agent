# Hindsight — Environment Configuration (Example)
# Copy this file to .env and fill in the empty fields

# LLM (OpenAI-compatible provider — e.g., 9Router, OpenAI, Groq)
HINDSIGHT_API_LLM_PROVIDER=openai
HINDSIGHT_API_LLM_API_KEY=
HINDSIGHT_API_LLM_BASE_URL=
HINDSIGHT_API_LLM_MODEL=hermes

# Embeddings via Ollama bge-m3 (OpenAI-compatible)
HINDSIGHT_API_EMBEDDINGS_PROVIDER=openai
HINDSIGHT_API_EMBEDDINGS_OPENAI_API_KEY=ollama
HINDSIGHT_API_EMBEDDINGS_OPENAI_MODEL=bge-m3:latest
HINDSIGHT_API_EMBEDDINGS_OPENAI_BASE_URL=http://host.containers.internal:11434/v1

# Reranker via TEI (in-container sidecar)
HINDSIGHT_API_RERANKER_PROVIDER=tei
HINDSIGHT_API_RERANKER_TEI_URL=http://tei:8080

# PostgreSQL (built-in via docker-compose db service)
HINDSIGHT_API_DATABASE_URL=postgresql://hindsight_user:hindsight_pass@db:5432/hindsight_db

# Control Plane (Web UI — set to protect the dashboard)
HINDSIGHT_CP_ACCESS_KEY=

# API Settings
HINDSIGHT_API_HOST=0.0.0.0
HINDSIGHT_API_PORT=8888
HINDSIGHT_API_LOG_LEVEL=info
